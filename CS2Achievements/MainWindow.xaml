<Window
	x:Class="CS2Achievements.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="clr-namespace:CS2Achievements"
	Title="CS2 Achievements"
	Width="960"
	Height="640"
	MinWidth="640"
	MinHeight="480"
	Background="#171A21"
	Icon="icon.ico"
	Loaded="Window_Loaded"
	WindowStartupLocation="CenterScreen"
	WindowStyle="None">

	<WindowChrome.WindowChrome>
		<WindowChrome
			CaptionHeight="36"
			CornerRadius="0"
			GlassFrameThickness="0"
			ResizeBorderThickness="6"
			UseAeroCaptionButtons="False" />
	</WindowChrome.WindowChrome>

	<Window.Resources>
		<local:LogLevelToColorConverter x:Key="LogLevelColor" />
		<BooleanToVisibilityConverter x:Key="BoolToVis" />
		<local:ProgressToColorConverter x:Key="ProgressColor" />

		<Style TargetType="ScrollBar">
			<Style.Triggers>
				<Trigger Property="Orientation" Value="Vertical">
					<Setter Property="Width" Value="10" />
					<Setter Property="MinWidth" Value="10" />
					<Setter Property="Template">
						<Setter.Value>
							<ControlTemplate TargetType="ScrollBar">
								<Grid Background="Transparent">
									<Track x:Name="PART_Track" IsDirectionReversed="True">
										<Track.DecreaseRepeatButton>
											<RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
										</Track.DecreaseRepeatButton>
										<Track.IncreaseRepeatButton>
											<RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
										</Track.IncreaseRepeatButton>
										<Track.Thumb>
											<Thumb>
												<Thumb.Template>
													<ControlTemplate TargetType="Thumb">
														<Border
															x:Name="ThumbBd"
															Margin="2,0"
															Background="#3D5166"
															CornerRadius="5" />
														<ControlTemplate.Triggers>
															<Trigger Property="IsMouseOver" Value="True">
																<Setter TargetName="ThumbBd" Property="Background" Value="#5A8AB5" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Thumb.Template>
											</Thumb>
										</Track.Thumb>
									</Track>
								</Grid>
							</ControlTemplate>
						</Setter.Value>
					</Setter>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="CaptionBtn" TargetType="Button">
			<Setter Property="Width" Value="46" />
			<Setter Property="Height" Value="36" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Foreground" Value="#8F98A0" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd" Background="{TemplateBinding Background}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#2A475E" />
								<Setter Property="Foreground" Value="#C7D5E0" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style
			x:Key="CloseBtn"
			BasedOn="{StaticResource CaptionBtn}"
			TargetType="Button">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd" Background="Transparent">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#E81123" />
								<Setter Property="Foreground" Value="White" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="TabBtn" TargetType="RadioButton">
			<Setter Property="Foreground" Value="#8F98A0" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="FontFamily" Value="Segoe UI" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="RadioButton">
						<Border
							x:Name="Bd"
							Padding="20,10"
							Background="Transparent">
							<TextBlock
								HorizontalAlignment="Center"
								FontSize="{TemplateBinding FontSize}"
								FontWeight="{TemplateBinding FontWeight}"
								Foreground="{TemplateBinding Foreground}"
								Text="{TemplateBinding Content}" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#1E3A52" />
								<Setter Property="Foreground" Value="#C7D5E0" />
							</Trigger>
							<Trigger Property="IsChecked" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#1B2838" />
								<Setter Property="Foreground" Value="#66C0F4" />
								<Setter TargetName="Bd" Property="BorderBrush" Value="#66C0F4" />
								<Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,2" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="SearchBox" TargetType="TextBox">
			<Setter Property="Background" Value="#141D26" />
			<Setter Property="Foreground" Value="#C7D5E0" />
			<Setter Property="CaretBrush" Value="#C7D5E0" />
			<Setter Property="BorderBrush" Value="#2A3F5F" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Padding" Value="8,6" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="FontFamily" Value="Segoe UI" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="2">
							<Grid>
								<ScrollViewer
									x:Name="PART_ContentHost"
									Margin="{TemplateBinding Padding}"
									VerticalScrollBarVisibility="Hidden" />
								<TextBlock
									x:Name="Placeholder"
									Margin="{TemplateBinding Padding}"
									Foreground="#556677"
									IsHitTestVisible="False"
									Text="{TemplateBinding Tag}"
									Visibility="Collapsed" />
							</Grid>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="Text" Value="">
								<Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
							</Trigger>
							<Trigger Property="IsFocused" Value="True">
								<Setter Property="BorderBrush" Value="#66C0F4" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="FilterBtn" TargetType="ToggleButton">
			<Setter Property="MinWidth" Value="38" />
			<Setter Property="Height" Value="26" />
			<Setter Property="Margin" Value="2,0" />
			<Setter Property="Padding" Value="6,2" />
			<Setter Property="Background" Value="#1A2634" />
			<Setter Property="Foreground" Value="#556677" />
			<Setter Property="BorderBrush" Value="#2A3F5F" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="FontSize" Value="10" />
			<Setter Property="FontWeight" Value="Bold" />
			<Setter Property="FontFamily" Value="Cascadia Mono,Consolas,Courier New" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ToggleButton">
						<Border
							x:Name="Bd"
							Padding="{TemplateBinding Padding}"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="2">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsChecked" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#2A475E" />
								<Setter Property="Foreground" Value="#66C0F4" />
								<Setter TargetName="Bd" Property="BorderBrush" Value="#4A7A9B" />
							</Trigger>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#1E3A52" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="SortBtn" TargetType="RadioButton">
			<Setter Property="MinWidth" Value="60" />
			<Setter Property="Height" Value="26" />
			<Setter Property="Margin" Value="2,0" />
			<Setter Property="Padding" Value="8,2" />
			<Setter Property="Foreground" Value="#556677" />
			<Setter Property="FontSize" Value="11" />
			<Setter Property="FontFamily" Value="Segoe UI" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="RadioButton">
						<Border
							x:Name="Bd"
							Padding="{TemplateBinding Padding}"
							Background="#1A2634"
							BorderBrush="#2A3F5F"
							BorderThickness="1"
							CornerRadius="2">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsChecked" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#2A475E" />
								<Setter Property="Foreground" Value="#66C0F4" />
								<Setter TargetName="Bd" Property="BorderBrush" Value="#4A7A9B" />
							</Trigger>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#1E3A52" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="SteamProgress" TargetType="ProgressBar">
			<Setter Property="Height" Value="6" />
			<Setter Property="Background" Value="#1A2634" />
			<Setter Property="Foreground" Value="#5C7E10" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ProgressBar">
						<Border
							Background="{TemplateBinding Background}"
							ClipToBounds="True"
							CornerRadius="3">
							<Grid>
								<Border x:Name="PART_Track" />
								<Border
									x:Name="PART_Indicator"
									HorizontalAlignment="Left"
									Background="{TemplateBinding Foreground}"
									CornerRadius="3" />
							</Grid>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style TargetType="CheckBox">
			<Setter Property="Foreground" Value="#C7D5E0" />
			<Setter Property="FontFamily" Value="Segoe UI" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="CheckBox">
						<Border
							x:Name="Bd"
							Width="36"
							Height="20"
							Background="#1A2634"
							BorderBrush="#2A3F5F"
							BorderThickness="1"
							CornerRadius="10">
							<Ellipse
								x:Name="Knob"
								Width="14"
								Height="14"
								Margin="2,0,0,0"
								HorizontalAlignment="Left"
								Fill="#556677" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsChecked" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#2A475E" />
								<Setter TargetName="Bd" Property="BorderBrush" Value="#4A7A9B" />
								<Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
								<Setter TargetName="Knob" Property="Margin" Value="0,0,2,0" />
								<Setter TargetName="Knob" Property="Fill" Value="#66C0F4" />
							</Trigger>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="BorderBrush" Value="#4A7A9B" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style TargetType="Slider">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Slider">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="*" />
							</Grid.RowDefinitions>
							<Border
								Height="4"
								VerticalAlignment="Center"
								Background="#1A2634"
								BorderBrush="#2A3F5F"
								BorderThickness="1"
								ClipToBounds="True"
								CornerRadius="2">
								<Border
									x:Name="PART_SelectionRange"
									HorizontalAlignment="Left"
									Background="#4A7A9B"
									CornerRadius="2" />
							</Border>
							<Track x:Name="PART_Track">
								<Track.DecreaseRepeatButton>
									<RepeatButton Command="Slider.DecreaseLarge" Opacity="0" />
								</Track.DecreaseRepeatButton>
								<Track.IncreaseRepeatButton>
									<RepeatButton Command="Slider.IncreaseLarge" Opacity="0" />
								</Track.IncreaseRepeatButton>
								<Track.Thumb>
									<Thumb Cursor="Hand">
										<Thumb.Template>
											<ControlTemplate TargetType="Thumb">
												<Ellipse
													x:Name="ThumbEl"
													Width="16"
													Height="16"
													Fill="#66C0F4"
													Stroke="#4A7A9B"
													StrokeThickness="1" />
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="ThumbEl" Property="Fill" Value="#88D0FF" />
													</Trigger>
													<Trigger Property="IsDragging" Value="True">
														<Setter TargetName="ThumbEl" Property="Fill" Value="#4A9FD4" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Thumb.Template>
									</Thumb>
								</Track.Thumb>
							</Track>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Border
		x:Name="OuterBorder"
		BorderBrush="#2A3F5F"
		BorderThickness="1">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="36" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="28" />
			</Grid.RowDefinitions>

			<Grid Grid.Row="0" Background="#171A21">
				<StackPanel
					Margin="12,0,0,0"
					VerticalAlignment="Center"
					Orientation="Horizontal">
					<TextBlock
						FontFamily="Segoe UI"
						FontSize="14"
						FontWeight="Bold"
						Foreground="#66C0F4"
						Text="CS2" />
					<TextBlock
						FontFamily="Segoe UI"
						FontSize="14"
						FontWeight="Bold"
						Foreground="#8F98A0"
						Text=" ACHIEVEMENTS" />
					<TextBlock
						x:Name="TitleVersionText"
						Margin="8,0,0,0"
						VerticalAlignment="Center"
						FontFamily="Segoe UI"
						FontSize="10"
						Foreground="#556677" />
				</StackPanel>
				<StackPanel
					HorizontalAlignment="Right"
					Orientation="Horizontal"
					WindowChrome.IsHitTestVisibleInChrome="True">
					<Button
						Click="TrayClick"
						Content="▾"
						Style="{StaticResource CaptionBtn}"
						ToolTip="Minimize to tray" />
					<Button
						Click="MinimizeClick"
						Content="─"
						Style="{StaticResource CaptionBtn}" />
					<Button
						x:Name="MaxBtn"
						Click="MaximizeClick"
						Content="□"
						Style="{StaticResource CaptionBtn}" />
					<Button
						Click="CloseClick"
						Content="✕"
						Style="{StaticResource CloseBtn}" />
				</StackPanel>
			</Grid>

			<Border
				Grid.Row="1"
				Background="#171A21"
				BorderBrush="#2A3F5F"
				BorderThickness="0,0,0,1">
				<StackPanel Orientation="Horizontal">
					<RadioButton
						x:Name="TabLogs"
						Checked="Tab_Checked"
						Content="LOGS"
						IsChecked="True"
						Style="{StaticResource TabBtn}" />
					<RadioButton
						x:Name="TabConfig"
						Checked="Tab_Checked"
						Content="CONFIG"
						Style="{StaticResource TabBtn}" />
					<RadioButton
						x:Name="TabAchievements"
						Checked="Tab_Checked"
						Content="ACHIEVEMENTS"
						Style="{StaticResource TabBtn}" />
				</StackPanel>
			</Border>

			<Grid Grid.Row="2" Background="#1B2838">

				<Grid x:Name="LogsPanel" Visibility="Visible">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<Border
						Grid.Row="0"
						Padding="10,8"
						Background="#16202D"
						BorderBrush="#2A3F5F"
						BorderThickness="0,0,0,1">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<TextBox
								x:Name="LogSearch"
								Style="{StaticResource SearchBox}"
								Tag="Search logs..."
								TextChanged="LogSearch_TextChanged" />
							<StackPanel
								Grid.Column="1"
								Margin="10,0,0,0"
								VerticalAlignment="Center"
								Orientation="Horizontal">
								<ToggleButton
									x:Name="FilterVerbose"
									Checked="LogFilterChanged"
									Content="VRB"
									Style="{StaticResource FilterBtn}"
									Unchecked="LogFilterChanged" />
								<ToggleButton
									x:Name="FilterDebug"
									Checked="LogFilterChanged"
									Content="DBG"
									IsChecked="True"
									Style="{StaticResource FilterBtn}"
									Unchecked="LogFilterChanged" />
								<ToggleButton
									x:Name="FilterInfo"
									Checked="LogFilterChanged"
									Content="INF"
									IsChecked="True"
									Style="{StaticResource FilterBtn}"
									Unchecked="LogFilterChanged" />
								<ToggleButton
									x:Name="FilterWarn"
									Checked="LogFilterChanged"
									Content="WRN"
									IsChecked="True"
									Style="{StaticResource FilterBtn}"
									Unchecked="LogFilterChanged" />
								<ToggleButton
									x:Name="FilterError"
									Checked="LogFilterChanged"
									Content="ERR"
									IsChecked="True"
									Style="{StaticResource FilterBtn}"
									Unchecked="LogFilterChanged" />
								<ToggleButton
									x:Name="FilterFatal"
									Checked="LogFilterChanged"
									Content="FTL"
									IsChecked="True"
									Style="{StaticResource FilterBtn}"
									Unchecked="LogFilterChanged" />
							</StackPanel>
						</Grid>
					</Border>

					<ListBox
						x:Name="LogList"
						Grid.Row="1"
						Background="Transparent"
						BorderThickness="0"
						ScrollViewer.HorizontalScrollBarVisibility="Disabled"
						VirtualizingPanel.IsVirtualizing="True"
						VirtualizingPanel.ScrollUnit="Pixel">
						<ListBox.ItemContainerStyle>
							<Style TargetType="ListBoxItem">
								<Setter Property="HorizontalContentAlignment" Value="Stretch" />
								<Setter Property="Padding" Value="0" />
								<Setter Property="Margin" Value="0" />
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="ListBoxItem">
											<Border
												x:Name="Bd"
												Padding="10,3"
												Background="Transparent">
												<ContentPresenter />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="Bd" Property="Background" Value="#0CFFFFFF" />
												</Trigger>
												<Trigger Property="IsSelected" Value="True">
													<Setter TargetName="Bd" Property="Background" Value="#15FFFFFF" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</ListBox.ItemContainerStyle>
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="78" />
										<ColumnDefinition Width="38" />
										<ColumnDefinition Width="*" />
									</Grid.ColumnDefinitions>
									<TextBlock
										VerticalAlignment="Top"
										FontFamily="Cascadia Mono,Consolas,Courier New"
										FontSize="12"
										Foreground="#556677"
										Text="{Binding Timestamp, StringFormat=HH:mm:ss.ff}" />
									<TextBlock
										Grid.Column="1"
										VerticalAlignment="Top"
										FontFamily="Cascadia Mono,Consolas,Courier New"
										FontSize="12"
										FontWeight="Bold"
										Foreground="{Binding Level, Converter={StaticResource LogLevelColor}}"
										Text="{Binding LevelShort}" />
									<TextBlock
										Grid.Column="2"
										FontFamily="Cascadia Mono,Consolas,Courier New"
										FontSize="12"
										Foreground="#C7D5E0"
										Text="{Binding Message}"
										TextWrapping="Wrap" />
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</Grid>

				<Grid x:Name="ConfigPanel" Visibility="Collapsed">
					<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
						<StackPanel
							MaxWidth="700"
							Margin="24,20"
							HorizontalAlignment="Left">

							<TextBlock
								Margin="0,0,0,12"
								FontFamily="Segoe UI"
								FontSize="12"
								FontWeight="Bold"
								Foreground="#66C0F4"
								Text="NOTIFICATIONS" />

							<Border
								Margin="0,0,0,6"
								Padding="16,14"
								Background="#16202D"
								CornerRadius="3">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition />
										<RowDefinition />
									</Grid.RowDefinitions>
									<TextBlock
										Margin="0,0,0,4"
										FontFamily="Segoe UI"
										FontSize="13"
										Foreground="#C7D5E0"
										Text="Progress popup frequency" />
									<TextBlock
										Grid.Row="0"
										Margin="0,20,0,0"
										FontFamily="Segoe UI"
										FontSize="11"
										Foreground="#556677"
										Text="Controls when in-progress achievement popups appear." />
									<StackPanel
										Grid.Row="1"
										Margin="0,10,0,0"
										Orientation="Horizontal">
										<RadioButton
											x:Name="PopupAlways"
											Checked="PopupMode_Changed"
											Content="Always"
											GroupName="PopupMode"
											Style="{StaticResource SortBtn}" />
										<RadioButton
											x:Name="PopupRoundEnd"
											Checked="PopupMode_Changed"
											Content="On Round End"
											GroupName="PopupMode"
											Style="{StaticResource SortBtn}" />
										<RadioButton
											x:Name="PopupMilestones"
											Checked="PopupMode_Changed"
											Content="At Milestones (Every 10%)"
											GroupName="PopupMode"
											Style="{StaticResource SortBtn}" />
									</StackPanel>
								</Grid>
							</Border>

							<Border
								Margin="0,0,0,6"
								Padding="16,14"
								Background="#16202D"
								CornerRadius="3">
								<Grid>
									<TextBlock
										FontFamily="Segoe UI"
										FontSize="13"
										Foreground="#C7D5E0"
										Text="Show unlock popups" />
									<CheckBox
										x:Name="ShowUnlockCheck"
										HorizontalAlignment="Right"
										VerticalAlignment="Center"
										Checked="ShowUnlock_Changed"
										Unchecked="ShowUnlock_Changed" />
								</Grid>
							</Border>

							<TextBlock
								Margin="0,24,0,12"
								FontFamily="Segoe UI"
								FontSize="12"
								FontWeight="Bold"
								Foreground="#66C0F4"
								Text="POPUP APPEARANCE" />

							<Border
								Margin="0,0,0,6"
								Padding="16,14"
								Background="#16202D"
								CornerRadius="3">
								<StackPanel>
									<TextBlock
										Margin="0,0,0,4"
										FontFamily="Segoe UI"
										FontSize="13"
										Foreground="#C7D5E0"
										Text="Popup position" />
									<TextBlock
										Margin="0,0,0,10"
										FontFamily="Segoe UI"
										FontSize="11"
										Foreground="#556677"
										Text="Corner of the CS2 window where popups appear." />
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="*" />
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition />
											<RowDefinition />
										</Grid.RowDefinitions>
										<RadioButton
											x:Name="PosTopLeft"
											Grid.Row="0"
											Grid.Column="0"
											Margin="0,0,4,4"
											Checked="PopupPosition_Changed"
											Content="Top Left"
											GroupName="PopupPos"
											Style="{StaticResource SortBtn}" />
										<RadioButton
											x:Name="PosTopRight"
											Grid.Row="0"
											Grid.Column="1"
											Margin="4,0,0,4"
											Checked="PopupPosition_Changed"
											Content="Top Right"
											GroupName="PopupPos"
											Style="{StaticResource SortBtn}" />
										<RadioButton
											x:Name="PosBottomLeft"
											Grid.Row="1"
											Grid.Column="0"
											Margin="0,0,4,0"
											Checked="PopupPosition_Changed"
											Content="Bottom Left"
											GroupName="PopupPos"
											Style="{StaticResource SortBtn}" />
										<RadioButton
											x:Name="PosBottomRight"
											Grid.Row="1"
											Grid.Column="1"
											Margin="4,0,0,0"
											Checked="PopupPosition_Changed"
											Content="Bottom Right"
											GroupName="PopupPos"
											Style="{StaticResource SortBtn}" />
									</Grid>
								</StackPanel>
							</Border>

							<Border
								Margin="0,0,0,6"
								Padding="16,14"
								Background="#16202D"
								CornerRadius="3">
								<StackPanel>
									<Grid Margin="0,0,0,8">
										<TextBlock
											FontFamily="Segoe UI"
											FontSize="13"
											Foreground="#C7D5E0"
											Text="Popup scale" />
										<TextBlock
											x:Name="ScaleValueText"
											HorizontalAlignment="Right"
											FontFamily="Segoe UI"
											FontSize="13"
											Foreground="#C7D5E0"
											Text="1.0" />
									</Grid>
									<Slider
										x:Name="PopupScaleSlider"
										IsSnapToTickEnabled="True"
										Maximum="3.0"
										Minimum="0.5"
										TickFrequency="0.1"
										ValueChanged="PopupScale_Changed"
										Value="1.0" />
								</StackPanel>
							</Border>

							<Border
								Margin="0,0,0,6"
								Padding="16,14"
								Background="#16202D"
								CornerRadius="3">
								<Grid>
									<StackPanel VerticalAlignment="Center">
										<TextBlock
											FontFamily="Segoe UI"
											FontSize="13"
											Foreground="#C7D5E0"
											Text="Test popup" />
										<TextBlock
											Margin="0,2,0,0"
											FontFamily="Segoe UI"
											FontSize="11"
											Foreground="#556677"
											Text="Show a sample popup using the current position and scale settings." />
									</StackPanel>
									<Button
										Padding="16,6"
										HorizontalAlignment="Right"
										VerticalAlignment="Center"
										Click="TestPopup_Click"
										Content="TEST"
										Cursor="Hand"
										FontFamily="Segoe UI"
										FontSize="11"
										FontWeight="Bold"
										Foreground="White"
										WindowChrome.IsHitTestVisibleInChrome="True">
										<Button.Template>
											<ControlTemplate TargetType="Button">
												<Border
													x:Name="Bd"
													Padding="{TemplateBinding Padding}"
													Background="#1A5276"
													CornerRadius="2">
													<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="Bd" Property="Background" Value="#2471A3" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Button.Template>
									</Button>
								</Grid>
							</Border>

							<TextBlock
								Margin="0,24,0,12"
								FontFamily="Segoe UI"
								FontSize="12"
								FontWeight="Bold"
								Foreground="#66C0F4"
								Text="DATA" />

							<Border
								Margin="0,0,0,6"
								Padding="16,14"
								Background="#16202D"
								CornerRadius="3">
								<Grid>
									<StackPanel>
										<TextBlock
											FontFamily="Segoe UI"
											FontSize="13"
											Foreground="#C7D5E0"
											Text="Current profile" />
										<TextBlock
											x:Name="ConfigSteamIdText"
											Margin="0,2,0,0"
											FontFamily="Segoe UI"
											FontSize="11"
											Foreground="#556677" />
									</StackPanel>
								</Grid>
							</Border>

							<Border
								Margin="0,0,0,6"
								Padding="16,14"
								Background="#16202D"
								CornerRadius="3">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<StackPanel
										Grid.Column="0"
										Margin="0,0,16,0"
										VerticalAlignment="Center">
										<TextBlock
											FontFamily="Segoe UI"
											FontSize="13"
											Foreground="#C7D5E0"
											Text="Reset all achievement progress" />
										<TextBlock
											Margin="0,2,0,0"
											FontFamily="Segoe UI"
											FontSize="11"
											Foreground="#556677"
											Text="This cannot be undone. Resets progress for the currently loaded Steam account only."
											TextWrapping="Wrap" />
									</StackPanel>
									<Button
										x:Name="ResetBtn"
										Grid.Column="1"
										Padding="16,6"
										HorizontalAlignment="Right"
										VerticalAlignment="Center"
										Click="ResetProgress_Click"
										Content="RESET"
										Cursor="Hand"
										FontFamily="Segoe UI"
										FontSize="11"
										FontWeight="Bold"
										Foreground="White"
										WindowChrome.IsHitTestVisibleInChrome="True">
										<Button.Template>
											<ControlTemplate TargetType="Button">
												<Border
													x:Name="Bd"
													Padding="{TemplateBinding Padding}"
													Background="#8B2E2E"
													CornerRadius="2">
													<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="Bd" Property="Background" Value="#B83C3C" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Button.Template>
									</Button>
								</Grid>
							</Border>

							<Border
								Margin="0,0,0,6"
								Padding="16,14"
								Background="#16202D"
								CornerRadius="3">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<TextBlock
										Grid.Column="0"
										VerticalAlignment="Center"
										FontFamily="Segoe UI"
										FontSize="13"
										Foreground="#C7D5E0"
										Text="Open data folder" />
									<Button
										Grid.Column="1"
										Margin="12,0,0,0"
										Padding="12,6"
										Background="#2A475E"
										BorderThickness="0"
										Click="OpenDataFolder_Click"
										Cursor="Hand"
										FontFamily="Segoe UI"
										FontSize="11"
										Foreground="#C7D5E0">
										Open Folder
									</Button>
								</Grid>
							</Border>

							<TextBlock
								Margin="0,24,0,12"
								FontFamily="Segoe UI"
								FontSize="12"
								FontWeight="Bold"
								Foreground="#66C0F4"
								Text="VERSION" />

							<Border
								Margin="0,0,0,20"
								Padding="16,14"
								Background="#16202D"
								CornerRadius="3">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<StackPanel Grid.Column="0" VerticalAlignment="Center">
										<TextBlock
											x:Name="VersionInfoText"
											FontFamily="Segoe UI"
											FontSize="12"
											Foreground="#C7D5E0" />
										<TextBlock
											x:Name="UpdateStatusText"
											Margin="0,4,0,0"
											FontFamily="Segoe UI"
											FontSize="11"
											Foreground="#556677" />
									</StackPanel>
									<Button
										Grid.Column="1"
										Margin="12,0,0,0"
										Padding="12,6"
										VerticalAlignment="Center"
										Background="#2A475E"
										BorderThickness="0"
										Click="CheckForUpdates_Click"
										Cursor="Hand"
										FontFamily="Segoe UI"
										FontSize="11"
										Foreground="#C7D5E0">
										Check for Updates
									</Button>
								</Grid>
							</Border>

						</StackPanel>
					</ScrollViewer>
				</Grid>

				<Grid x:Name="AchievementsPanel" Visibility="Collapsed">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<Border
						Grid.Row="0"
						Padding="10,8"
						Background="#16202D"
						BorderBrush="#2A3F5F"
						BorderThickness="0,0,0,1">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<TextBox
								x:Name="AchievementSearch"
								Style="{StaticResource SearchBox}"
								Tag="Search achievements..."
								TextChanged="AchievementSearch_TextChanged" />
							<StackPanel
								Grid.Column="1"
								Margin="10,0,0,0"
								VerticalAlignment="Center"
								Orientation="Horizontal">
								<TextBlock
									Margin="0,0,6,0"
									VerticalAlignment="Center"
									FontFamily="Segoe UI"
									FontSize="11"
									Foreground="#556677"
									Text="Sort:" />
								<RadioButton
									x:Name="SortCategory"
									Checked="AchievementSortChanged"
									Content="Category"
									GroupName="ASort"
									IsChecked="True"
									Style="{StaticResource SortBtn}" />
								<RadioButton
									x:Name="SortName"
									Checked="AchievementSortChanged"
									Content="Name"
									GroupName="ASort"
									Style="{StaticResource SortBtn}" />
								<RadioButton
									x:Name="SortProgress"
									Checked="AchievementSortChanged"
									Content="Progress"
									GroupName="ASort"
									Style="{StaticResource SortBtn}" />
							</StackPanel>
							<TextBlock
								x:Name="AchievementCount"
								Grid.Column="2"
								Margin="12,0,0,0"
								VerticalAlignment="Center"
								FontFamily="Segoe UI"
								FontSize="12"
								Foreground="#556677" />
						</Grid>
					</Border>

					<ListBox
						x:Name="AchievementListBox"
						Grid.Row="1"
						Background="Transparent"
						BorderThickness="0"
						ScrollViewer.HorizontalScrollBarVisibility="Disabled"
						VirtualizingPanel.IsVirtualizing="True"
						VirtualizingPanel.ScrollUnit="Pixel">
						<ListBox.GroupStyle>
							<GroupStyle>
								<GroupStyle.ContainerStyle>
									<Style TargetType="GroupItem">
										<Setter Property="Template">
											<Setter.Value>
												<ControlTemplate TargetType="GroupItem">
													<StackPanel>
														<Border
															Margin="0,8,0,0"
															Padding="14,10"
															Background="#12192B"
															BorderBrush="#2A3F5F"
															BorderThickness="0,0,0,1">
															<Grid>
																<TextBlock
																	FontFamily="Segoe UI"
																	FontSize="13"
																	FontWeight="Bold"
																	Foreground="#66C0F4">
																	<Run Text="{Binding Name, Mode=OneWay}" />
																</TextBlock>
																<TextBlock
																	HorizontalAlignment="Right"
																	VerticalAlignment="Center"
																	FontFamily="Segoe UI"
																	FontSize="12"
																	Foreground="#556677">
																	<Run Text="{Binding ItemCount, Mode=OneWay}" />
																	<Run Text=" achievements" />
																</TextBlock>
															</Grid>
														</Border>
														<ItemsPresenter />
													</StackPanel>
												</ControlTemplate>
											</Setter.Value>
										</Setter>
									</Style>
								</GroupStyle.ContainerStyle>
							</GroupStyle>
						</ListBox.GroupStyle>
						<ListBox.ItemContainerStyle>
							<Style TargetType="ListBoxItem">
								<Setter Property="HorizontalContentAlignment" Value="Stretch" />
								<Setter Property="Padding" Value="0" />
								<Setter Property="Margin" Value="0" />
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="ListBoxItem">
											<Border
												x:Name="Bd"
												Margin="0,1,0,0"
												Padding="12,8"
												Background="#16202D">
												<ContentPresenter />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="Bd" Property="Background" Value="#1A2A3D" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</ListBox.ItemContainerStyle>
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="56" />
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>

									<Border
										Width="48"
										Height="48"
										VerticalAlignment="Center"
										Background="#0D0F13"
										CornerRadius="3">
										<Image
											Width="44"
											Height="44"
											Opacity="{Binding IconOpacity}"
											RenderOptions.BitmapScalingMode="HighQuality"
											Source="{Binding Icon}"
											Stretch="Uniform" />
									</Border>

									<StackPanel
										Grid.Column="1"
										Margin="12,0,12,0"
										VerticalAlignment="Center">
										<TextBlock
											FontFamily="Segoe UI"
											FontSize="13"
											FontWeight="SemiBold"
											Foreground="#C7D5E0"
											Text="{Binding Name}" />
										<TextBlock
											Margin="0,2,0,0"
											FontFamily="Segoe UI"
											FontSize="11"
											Foreground="#8F98A0"
											Text="{Binding Description}"
											TextWrapping="Wrap" />
										<ProgressBar
											Margin="0,6,0,0"
											Foreground="{Binding Complete, Converter={StaticResource ProgressColor}}"
											Maximum="{Binding MaxProgress, Mode=OneWay}"
											Style="{StaticResource SteamProgress}"
											Visibility="{Binding HasProgress, Converter={StaticResource BoolToVis}}"
											Value="{Binding Progress, Mode=OneWay}" />
									</StackPanel>

									<StackPanel
										Grid.Column="2"
										MinWidth="70"
										HorizontalAlignment="Right"
										VerticalAlignment="Center">
										<TextBlock
											HorizontalAlignment="Right"
											FontFamily="Segoe UI"
											FontSize="12"
											Foreground="#8F98A0"
											Text="{Binding ProgressText}" />
										<TextBlock
											Margin="0,2,0,0"
											HorizontalAlignment="Right"
											FontFamily="Segoe UI"
											FontSize="10"
											FontWeight="Bold"
											Foreground="#5C7E10"
											Text="✓ UNLOCKED"
											Visibility="{Binding Complete, Converter={StaticResource BoolToVis}}" />
									</StackPanel>
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</Grid>
			</Grid>

			<Border
				Grid.Row="3"
				Background="#171A21"
				BorderBrush="#2A3F5F"
				BorderThickness="0,1,0,0">
				<Grid Margin="12,0">
					<StackPanel VerticalAlignment="Center" Orientation="Horizontal">
						<Ellipse
							x:Name="StatusDot"
							Width="8"
							Height="8"
							Margin="0,0,6,0"
							Fill="#5C7E10" />
						<TextBlock
							x:Name="StatusText"
							FontFamily="Segoe UI"
							FontSize="11"
							Foreground="#8F98A0"
							Text="Starting..." />
					</StackPanel>
					<TextBlock
						x:Name="SteamIdText"
						HorizontalAlignment="Right"
						VerticalAlignment="Center"
						FontFamily="Segoe UI"
						FontSize="11"
						Foreground="#556677" />
				</Grid>
			</Border>
		</Grid>
	</Border>
</Window>
